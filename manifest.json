{
  "manifest_version": 3,
  "name": "Web-to-AI Context Chat",
  "version": "0.1.0",
  "description": "Bring webpage tables and visible-area screenshots into an AI chat overlay as context.",
  "permissions": ["storage", "contextMenus", "activeTab", "notifications", "tabs", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "显示 Chat 图标"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/loader.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
